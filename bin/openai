#!/usr/bin/env bash

MODEL="gpt-4o-mini"
JSON_MODE=false
USER_PROMPT=()

if [ $# -lt 1 ]; then
cat << HELP
Usage: openai <prompt> [flags]

Flags:
  -m, --model   OpenAI Model, default: '${MODEL}'
  -j, --json    Force output to be strictly JSON

HELP
exit 1
fi

export OPENAI_API_KEY="$(pass show openai/api-key 2>/dev/null)"

if [[ -z "${OPENAI_API_KEY:-}" ]]; then
  echo "Error: 'OPENAI_API_KEY' environment variable is not set" >&2
  exit 1
fi

while [[ $# -gt 0 ]]; do
  case $1 in
    -m|--model)
      MODEL="${2}"
      shift 2
      ;;
    -j|--json)
      JSON_MODE=true
      shift
      ;;
    *)
      USER_PROMPT+=("$1")
      shift
      ;;
  esac
done

if [[ ${#USER_PROMPT[@]} -eq 0 ]]; then
  echo "Error: prompt is required" >&2
  exit 1
fi

# Build the JSON payload dynamically via stdin to avoid "argument list too long" errors
if [[ "$JSON_MODE" == true ]]; then
  PAYLOAD=$(printf "%s (Output in JSON)" "${USER_PROMPT[*]}" | jq -Rs \
    --arg model "$MODEL" \
    '{
      model: $model,
      messages: [{role: "user", content: .}],
      response_format: { type: "json_object" }
    }')
else
  PAYLOAD=$(printf "%s" "${USER_PROMPT[*]}" | jq -Rs \
    --arg model "$MODEL" \
    '{
      model: $model,
      messages: [{role: "user", content: .}]
    }')
fi

# Send the request to the OpenAI API
curl -s https://api.openai.com/v1/chat/completions \
  -H "Authorization: Bearer $OPENAI_API_KEY" \
  -H "Content-Type: application/json" \
  -d "$PAYLOAD" \
| jq -r '.choices[0].message.content // "Error: Could not parse response. Raw output:\n" + tostring'
