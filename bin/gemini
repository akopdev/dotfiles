#!/usr/bin/env bash

MODEL="gemini-2.5-flash"
MIME_TYPE="text/plain"
USER_PROMPT=()

if [ $# -lt 1 ]; then
cat << HELP
Usage: gemini <prompt> [flags]

Flags:
  -m, --model   Gemini Model, default: '${MODEL}'
  -j, --json    Force output to be strictly JSON

HELP
return
fi


export GEMINI_API_KEY="$(pass show gemini/api-key 2>/dev/null)"

if [[ -z "${GEMINI_API_KEY:-}" ]]; then
  echo "Error: 'GEMINI_API_KEY' environment variable is not set" >&2
  return
fi

while [[ $# -gt 0 ]]; do
  case $1 in
    -m|--model)
      MODEL="${2}"
      shift 2
      ;;
    -j|--json)
      MIME_TYPE="application/json"
      shift
      ;;
    *)
      USER_PROMPT+=("$1")
      shift
      ;;
  esac
done

if [[ ${#USER_PROMPT[@]} -eq 0 ]]; then
  echo "Error: prompt is required" >&2
  return
fi

PAYLOAD=$(jq -n \
  --arg text "${USER_PROMPT[*]}" \
  --arg mime "${MIME_TYPE}" \
  '{
    contents: [{
      parts: [{
        text: $text
      }]
    }],
    generationConfig: {
      responseMimeType: $mime
    }
  }')

curl -s -X POST "https://generativelanguage.googleapis.com/v1beta/models/${MODEL}:generateContent" \
  -H "x-goog-api-key: ${GEMINI_API_KEY}" \
  -H "Content-Type: application/json" \
  -d "$PAYLOAD" \
| jq -r '.candidates[0].content.parts[0].text // "Error: Could not parse response. Raw output:\n" + tostring'
